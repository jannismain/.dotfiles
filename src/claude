# Claude Code via Requesty
export ANTHROPIC_BASE_URL="https://router.eu.requesty.ai"
export ANTHROPIC_AUTH_TOKEN="${REQUESTY_API_KEY}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="vertex/claude-sonnet-4-6@europe-west1"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="vertex/claude-haiku-4-5@europe-west1"
# export ANTHROPIC_DEFAULT_HAIKU_MODEL="bedrock/claude-haiku-4-5@eu-central-1"
export ANTHROPIC_DEFAULT_OPUS_MODEL="vertex/claude-opus-4-8@eu"
# export ANTHROPIC_DEFAULT_OPUS_MODEL="bedrock/claude-opus-4-8@eu-west-3"

alias ccusage='pnpx ccusage "$@"'
alias claude-usage='ccusage'
alias opencode-usage='pnpx @ccusage/opencode@latest "$@"'

# Claude Code with Deepseek
function claude-deepseek() {
  env \
    -u ANTHROPIC_DEFAULT_HAIKU_MODEL \
    -u ANTHROPIC_DEFAULT_SONNET_MODEL \
    -u ANTHROPIC_DEFAULT_OPUS_MODEL \
    ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic \
    ANTHROPIC_AUTH_TOKEN="${DEEPSEEK_API_KEY}" \
    ANTHROPIC_MODEL=deepseek-v4-pro \
    ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash \
    command claude "$@"
}

alias cl="claude"
alias cld="claude-deepseek"
