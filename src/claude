#!/bin/sh
alias agentbox="~/ext/agentbox/agentbox"

source ~/.dotfiles/private/secrets
# export ENABLE_TOOL_SEARCH=0
export CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
export CLAUDE_CODE_ENABLE_TELEMETRY=0
export ANTHROPIC_BASE_URL="https://api.portkey.ai"
export ANTHROPIC_AUTH_TOKEN="dummy"
export ANTHROPIC_CUSTOM_HEADERS="x-portkey-api-key: ${PORTKEY_API_KEY}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="@vertex-ai/anthropic.claude-sonnet-4-6"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="@vertex-ai/anthropic.claude-haiku-4-5@20251001"
export ANTHROPIC_DEFAULT_OPUS_MODEL="@vertex-ai/anthropic.claude-opus-4-6"

alias ccusage='pnpx ccusage "$@"'
alias claude-usage='ccusage'
alias codex-usage='pnpx @ccusage/codex@latest "$@"'
alias opencode-usage='pnpx @ccusage/opencode@latest "$@"'
